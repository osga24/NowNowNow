const today = new Date();
---

<footer>
  <div class="rule"></div>
  <div class="inner">
    <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer" class="what">
      What is a /now page?
    </a>
    <span class="dot">·</span>
    <a href="https://osga.dev" target="_blank" rel="noopener noreferrer" class="what">
      More About OsGa.dev
    </a>
  </div>
</footer>

<style>
  footer {
    width: 100%;
    max-width: 41.25rem;
    margin: 0 auto;
    padding: 0 1.5rem 3rem;
    box-sizing: border-box;
  }

  .rule {
    border-top: 0.0625rem solid var(--ink);
    margin-bottom: 1.25rem;
  }

  .inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.4rem 0.6rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    color: var(--ink-light);
  }



  .what {
    color: var(--ink-light);
    text-decoration: underline;
    text-underline-offset: 0.125rem;
  }

  .what:hover {
    color: var(--ink);
    opacity: 1;
  }
</style>
