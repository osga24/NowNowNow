---
const today = new Date();
const updated = today.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<footer>
  <div class="rule"></div>
  <div class="inner">
    <span class="label">Last updated</span>
    <span class="date">{updated}</span>
    <span class="dot">·</span>
    <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer" class="what">
      What is a /now page?
    </a>
  </div>
</footer>

<style>
  footer {
    width: 100%;
    max-width: 660px;
    margin: 0 auto;
    padding: 0 1.5rem 3rem;
  }

  .rule {
    border-top: 1px solid var(--ink);
    margin-bottom: 1.25rem;
  }

  .inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.6rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    color: var(--ink-light);
  }

  .label {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.7rem;
  }

  .date {
    color: var(--ink);
  }

  .dot {
    color: var(--rule);
  }

  .what {
    color: var(--ink-light);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .what:hover {
    color: var(--ink);
    opacity: 1;
  }
</style>
