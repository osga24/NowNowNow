---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  photo?: { src: ImageMetadata; alt?: string };
  prevEntry?: { slug: string; title: string } | null;
  nextEntry?: { slug: string; title: string } | null;
}

const { title, pubDate, photo, prevEntry, nextEntry } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<article class="report">
  <header class="report-header">
    <h1 class="report-title">{title}</h1>
    <div class="report-rule"></div>
  </header>

  <div class="prose">
    <slot />
  </div>

  {photo && (
    <section class="photo-section">
      <figure class="photo-item">
        <Image
          src={photo.src}
          alt={photo.alt ?? ''}
          class="photo-img"
          widths={[540, 800]}
          sizes="(min-width: 640px) 480px, 100vw"
        />
        {photo.alt && <figcaption class="photo-caption">{photo.alt}</figcaption>}
      </figure>
    </section>
  )}

  {(prevEntry || nextEntry) && (
    <nav class="report-nav">
      <div class="rule"></div>
      <div class="nav-inner">
        {prevEntry ? (
          <a href={`${base}/${prevEntry.slug}`} class="nav-link nav-prev">
            <span class="nav-label">← 上個月</span>
            <span class="nav-title">{prevEntry.title}</span>
          </a>
        ) : <span />}
        {nextEntry ? (
          <a href={`${base}/${nextEntry.slug}`} class="nav-link nav-next">
            <span class="nav-label">下個月 →</span>
            <span class="nav-title">{nextEntry.title}</span>
          </a>
        ) : <span />}
      </div>
    </nav>
  )}
</article>

<style>
  .report {
    width: 100%;
  }

  .report-header {
    margin-bottom: 2.5rem;
  }

  .report-title {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 700;
    letter-spacing: -0.02rem;
    margin: 0 0 0.75rem;
    line-height: 1.15;
  }

  .report-rule {
    border-top: 0.0625rem solid var(--ink);
  }

  /* ── Photo ── */
  .photo-section {
    margin-top: 2.75rem;
    border-top: 0.0625rem solid var(--ink);
    padding-top: 1.5rem;
  }

  .photo-item {
    margin: 0 auto;
    width: min(30rem, 100%);
  }

  .photo-img {
    display: block;
    width: 100%;
    aspect-ratio: 9 / 16;
    height: auto;
    object-fit: cover;
    border-radius: 0.75rem;
  }

  .photo-caption {
    margin-top: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: var(--ink-light);
    line-height: 1.4;
    text-align: center;
  }

  /* ── Navigation ── */
  .report-nav {
    margin-top: 3rem;
  }

  .rule {
    border-top: 0.0625rem solid var(--rule);
    margin-bottom: 1.25rem;
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    text-decoration: none;
    max-width: 45%;
  }

  .nav-next {
    text-align: right;
    margin-left: auto;
  }

  .nav-label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.1rem;
    text-transform: uppercase;
    color: var(--ink-light);
  }

  .nav-title {
    font-size: 0.95rem;
    color: var(--ink);
    font-style: italic;
  }

  .nav-link:hover .nav-title {
    text-decoration: underline;
    text-underline-offset: 0.125rem;
  }
</style>
