---
import { getCollection, render } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MonthlyReport from '../layouts/MonthlyReport.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const entries = await getCollection('monthly');
entries.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latest = entries[0];
const prevEntry = entries[1] ?? null;

const { Content } = await render(latest);
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <MonthlyReport
        title={latest.data.title}
        description={latest.data.description}
        pubDate={latest.data.pubDate}
        slug={latest.id}
        photo={latest.data.photo}
        prevEntry={prevEntry ? { slug: prevEntry.id, title: prevEntry.data.title } : null}
      >
        <Content />
      </MonthlyReport>
    </main>
    <Footer />
  </body>
</html>
