---
import { getCollection, render } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MonthlyReport from '../layouts/MonthlyReport.astro';
import { SITE_TITLE } from '../consts';

export async function getStaticPaths() {
  const entries = await getCollection('monthly');
  entries.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return entries.map((entry, index) => ({
    params: { month: entry.id },
    props: {
      entry,
      prevEntry: entries[index + 1] ?? null,
      nextEntry: entries[index - 1] ?? null,
    },
  }));
}

const { entry, prevEntry, nextEntry } = Astro.props;
const { Content } = await render(entry);
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <BaseHead
      title={`${entry.data.title} — ${SITE_TITLE}`}
      description={entry.data.description}
    />
  </head>
  <body>
    <Header />
    <main>
      <MonthlyReport
        title={entry.data.title}
        description={entry.data.description}
        pubDate={entry.data.pubDate}
        slug={entry.id}
        photo={entry.data.photo}
        prevEntry={prevEntry ? { slug: prevEntry.id, title: prevEntry.data.title } : null}
        nextEntry={nextEntry ? { slug: nextEntry.id, title: nextEntry.data.title } : null}
      >
        <Content />
      </MonthlyReport>
    </main>
    <Footer />
  </body>
</html>
